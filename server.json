{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.AceDataCloud/mcp-seedance",
  "description": "MCP server for ByteDance Seedance AI video generation",
  "version": "2026.3.19.7",
  "repository": {
    "url": "https://github.com/AceDataCloud/MCPSeedance",
    "source": "github"
  },
  "packages": [
    {
      "identifier": "mcp-seedance",
      "version": "2026.3.19.7",
      "transport": {
        "type": "stdio"
      },
      "registryType": "pypi",
      "runtimeHint": "uvx",
      "environmentVariables": [
        {
          "name": "ACEDATACLOUD_API_TOKEN",
          "description": "API token from Ace Data Cloud (https://platform.acedata.cloud)",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "websiteUrl": "https://platform.acedata.cloud",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://seedance.mcp.acedata.cloud/mcp"
    }
  ]
}
